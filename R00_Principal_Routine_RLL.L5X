<Routines Use="Context">
<Routine Use="Target" Name="R00_Principal" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[######################################################################################################################################################################################
POWER ON  Y POWER OFF DE LA MAQUINA
######################################################################################################################################################################################]]>
</Comment>
<Text>
<![CDATA[OTE(POWER_ON);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIO(POWER_ON)OTE(POWER_OFF);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[#######################################################################################################################################################################################
BLINKER DE 1 SEG 
#######################################################################################################################################################################################]]>
</Comment>
<Text>
<![CDATA[XIC(POWER_ON)XIO(TIME_ON_1_SEG.DN)TON(TIEMPO_ON_1_SEG,?,?);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIC(TIEMPO_ON_1_SEG.DN)TON(TIME_ON_1_SEG,?,?);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[XIO(TIEMPO_ON_1_SEG.DN)OTE(BLINKER_1_SEG);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[#######################################################################################################################################################################################
SECUENCIA DE INICIALIZACION DE LA MAQUINA
#######################################################################################################################################################################################]]>
</Comment>
<Text>
<![CDATA[XIC(POWER_ON)TON(TIEMPOS_SECC_INICIAL[0],?,?);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[XIO(TIEMPOS_SECC_INICIAL[0].DN)[MOVE(0,Sec_Inicial) ,OTU(MAQUINA_INICIALIZADA) ,OTU(SECC_ORIGEN_ECHA) ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Text>
<![CDATA[XIC(TIEMPOS_SECC_INICIAL[0].DN)OSR(BIT_1_SEC_INICIAL,OSR_BIT_SEC_INICIAL);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Text>
<![CDATA[XIC(OSR_BIT_SEC_INICIAL)OTL(PASO_1_SEC_INICIAL);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[SECUENCIA DE INICIALIZACIÓN 
###############################################################################################################################
PASO 10
1. Desenclava bit de secuencia hecha.
###############################################################################################################################]]>
</Comment>
<Text>
<![CDATA[EQ(Sec_Inicial,0)XIC(PASO_1_SEC_INICIAL)XIO(MAQUINA_INICIALIZADA)XIO(SECC_ORIGEN_ECHA)MOVE(10,Sec_Inicial);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[===============================================================================================================================
Se espera un tiempo para activar bit del paso.
===============================================================================================================================]]>
</Comment>
<Text>
<![CDATA[EQ(Sec_Inicial,10)TON(TIEMPOS_SECC_INICIAL[1],?,?);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Text>
<![CDATA[EQ(Sec_Inicial,10)XIC(TIEMPOS_SECC_INICIAL[1].DN)OTU(PASO_1_SEC_INICIAL);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[###############################################################################################################################
PASO 20
1. SECCUENCIA INICIALIZACION RESETEA LOS MODULOS DE SEGURIDAD SI LOS PAROS DE EMERGENCIA Y PUERTAS ESTAN CERRADOS
###############################################################################################################################]]>
</Comment>
<Text>
<![CDATA[EQ(Sec_Inicial,10)XIO(PASO_1_SEC_INICIAL)MOVE(20,Sec_Inicial);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Comment>
<![CDATA[===============================================================================================================================
Se espera un tiempo para activar bit del paso.
===============================================================================================================================]]>
</Comment>
<Text>
<![CDATA[EQ(Sec_Inicial,20)[TON(TIEMPOS_SECC_INICIAL[2],?,?) ,OTE(DRIVER_RST_SEC_INICIAL) ];]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Comment>
<![CDATA[###############################################################################################################################
PASO 30
1. SECUENCIA DE INICIALIZACIÓN ENCIENDE LA SECUENCIA DE LA MÁQUINA MODO MANUAL
###############################################################################################################################]]>
</Comment>
<Text>
<![CDATA[EQ(Sec_Inicial,20)XIC(DRIVER_RST_SEC_INICIAL)XIC(TIEMPOS_SECC_INICIAL[2].DN)MOVE(30,Sec_Inicial);]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Comment>
<![CDATA[===============================================================================================================================
Se espera un tiempo para activar bit del paso.
===============================================================================================================================]]>
</Comment>
<Text>
<![CDATA[EQ(Sec_Inicial,30)TON(TIEMPOS_SECC_INICIAL[3],?,?);]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Comment>
<![CDATA[###############################################################################################################################
PASO 33
1. Deshabilitación de drivers festo.
###############################################################################################################################]]>
</Comment>
<Text>
<![CDATA[EQ(Sec_Inicial,30)XIO(Modo_Auto)XIC(TIEMPOS_SECC_INICIAL[3].DN)MOVE(33,Sec_Inicial);]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Comment>
<![CDATA[===============================================================================================================================
Se espera un tiempo para activar bit del paso.
===============================================================================================================================]]>
</Comment>
<Text>
<![CDATA[EQ(Sec_Inicial,33)TON(TIEMPOS_SECC_INICIAL[4],?,?);]]>
</Text>
</Rung>
<Rung Number="18" Type="N">
<Text>
<![CDATA[EQ(Sec_Inicial,33)OTE(Sec_Inicial_DRV.1);]]>
</Text>
</Rung>
<Rung Number="19" Type="N">
<Comment>
<![CDATA[###############################################################################################################################
PASO 34
1. Reinicio de drivers festo.
###############################################################################################################################]]>
</Comment>
<Text>
<![CDATA[EQ(Sec_Inicial,33)XIC(TIEMPOS_SECC_INICIAL[4].DN)XIC(Sec_Inicial_DRV.1)XIO(Trigger_Enable_E1_TP)MOVE(34,Sec_Inicial);]]>
</Text>
</Rung>
<Rung Number="20" Type="N">
<Comment>
<![CDATA[===============================================================================================================================
Se espera un tiempo para activar bit del paso.
===============================================================================================================================]]>
</Comment>
<Text>
<![CDATA[EQ(Sec_Inicial,34)TON(TIEMPOS_SECC_INICIAL[5],?,?);]]>
</Text>
</Rung>
<Rung Number="21" Type="N">
<Text>
<![CDATA[EQ(Sec_Inicial,34)OTE(Sec_Inicial_DRV.2);]]>
</Text>
</Rung>
<Rung Number="22" Type="N">
<Comment>
<![CDATA[###############################################################################################################################
PASO 35
1. Habilitación de drivers festo.
###############################################################################################################################]]>
</Comment>
<Text>
<![CDATA[EQ(Sec_Inicial,34)XIC(TIEMPOS_SECC_INICIAL[5].DN)XIC(Sec_Inicial_DRV.2)MOVE(35,Sec_Inicial);]]>
</Text>
</Rung>
<Rung Number="23" Type="N">
<Comment>
<![CDATA[===============================================================================================================================
Se espera un tiempo para activar bit del paso.
===============================================================================================================================]]>
</Comment>
<Text>
<![CDATA[EQ(Sec_Inicial,35)TON(TIEMPOS_SECC_INICIAL[6],?,?);]]>
</Text>
</Rung>
<Rung Number="24" Type="N">
<Text>
<![CDATA[EQ(Sec_Inicial,35)OTE(Sec_Inicial_DRV.0);]]>
</Text>
</Rung>
<Rung Number="25" Type="N">
<Comment>
<![CDATA[###############################################################################################################################
PASO 40
1. Se enclava bit de secuencia hecha.
###############################################################################################################################]]>
</Comment>
<Text>
<![CDATA[EQ(Sec_Inicial,35)XIC(TIEMPOS_SECC_INICIAL[6].DN)XIC(Sec_Inicial_DRV.0)XIC(Trigger_Enable_E1_TP)MOVE(40,Sec_Inicial);]]>
</Text>
</Rung>
<Rung Number="26" Type="N">
<Comment>
<![CDATA[===============================================================================================================================
Se espera un tiempo para activar bit del paso.
===============================================================================================================================]]>
</Comment>
<Text>
<![CDATA[EQ(Sec_Inicial,40)[TON(TIEMPOS_SECC_INICIAL[4],?,?) ,OTL(MAQUINA_INICIALIZADA) ];]]>
</Text>
</Rung>
<Rung Number="27" Type="N">
<Comment>
<![CDATA[###############################################################################################################################
PASO 00
1. Secuencia se mueve al paso cero.
###############################################################################################################################]]>
</Comment>
<Text>
<![CDATA[EQ(Sec_Inicial,40)XIC(MAQUINA_INICIALIZADA)XIC(TIEMPOS_SECC_INICIAL[4].DN)XIO(Modo_Auto)MOVE(0,Sec_Inicial);]]>
</Text>
</Rung>
<Rung Number="28" Type="N">
<Comment>
<![CDATA[=====================================================================================================================================================================================
SELECCION ENTRE MODO MANUAL Y MODO AUTOMATICO
====================================================================================================================================================================================]]>
</Comment>
<Text>
<![CDATA[XIC(HMI_MODO_AUTOMATICO)OSR(BIT_MODO_AUTO_ON,OSR_MODO_AUTO_ON);]]>
</Text>
</Rung>
<Rung Number="29" Type="N">
<Text>
<![CDATA[XIC(OSR_MODO_AUTO_ON)XIO(Modo_Auto)OTL(ON_MODO_AUTO);]]>
</Text>
</Rung>
<Rung Number="30" Type="N">
<Text>
<![CDATA[XIC(ON_MODO_AUTO)[XIC(Modo_Auto) ,XIC(ERROR_GENERAL) ]OTU(ON_MODO_AUTO);]]>
</Text>
</Rung>
<Rung Number="31" Type="N">
<Comment>
<![CDATA[=====================================================================================================================================================================================
SELECCION ENTRE MODO MANUAL Y MODO AUTOMATICO
====================================================================================================================================================================================]]>
</Comment>
<Text>
<![CDATA[XIC(ON_MODO_AUTO)XIC(SECC_ORIGEN_ECHA)XIO(Modo_Auto)XIC(COND_CIL_12_CONTRAIDO)XIC(COND_CIL_13_CONTRAIDO)XIC(PV_SERVO_STATUS)OTL(Modo_Auto);]]>
</Text>
</Rung>
<Rung Number="32" Type="N">
<Text>
<![CDATA[[XIC(MODO_AUTO_OFF) XIC(STOP_SEC_AUTO) XIC(Modo_Auto) ,NE(Sec_Inicial,0) ,XIO(ENTRADA_L3_I_00) ,[XIO(POWER_ON) ,XIC(EN_AOI_MOVEP_P1) ,XIC(EN_AOI_MOVEP_P2) ,XIC(EN_AOI_MOVEP_mm) ,XIC(EN_AOI_Get_Position) ,XIC(EN_AOI_TEACH) ] ONS(ONS.0) ]OTU(Modo_Auto);]]>
</Text>
</Rung>
<Rung Number="33" Type="N">
<Text>
<![CDATA[ONS(HMI_MODO_AUTOMATICO)XIO(MAQ_EN_SECC_ON_AUTO)OTL(MODO_AUTO_OFF);]]>
</Text>
</Rung>
<Rung Number="34" Type="N">
<Text>
<![CDATA[XIC(MODO_AUTO_OFF)XIO(Modo_Auto)XIO(ENTRADA_L5_I_26)OTU(MODO_AUTO_OFF);]]>
</Text>
</Rung>
<Rung Number="35" Type="N">
<Comment>
<![CDATA[######################################################################################################################################################################################
ENVIA MSJ AL HMI 19 MAQUINA SIN ORIGEN
######################################################################################################################################################################################]]>
</Comment>
<Text>
<![CDATA[XIO(Modo_Auto)XIO(SECC_ORIGEN_ECHA)[XIC(ENTRADA_L4_I_15) ,XIC(ENTRADA_L6_I_11) ]XIO(MSJ_18_PALLET_EN_INDEX_SALIDA)NE(SEC_ORIGEN_IN,16)MOVE(19,MENSAJE_DE_OPERACION);]]>
</Text>
</Rung>
<Rung Number="36" Type="N">
<Comment>
<![CDATA[######################################################################################################################################################################################
ENVIA MSJ AL HMI 20 EN MODO MANUAL
######################################################################################################################################################################################]]>
</Comment>
<Text>
<![CDATA[XIO(Modo_Auto)XIC(SECC_ORIGEN_ECHA)XIO(ENTRADA_L5_I_26)[XIC(ENTRADA_L4_I_15) ,XIC(ENTRADA_L6_I_11) ]MOVE(20,MENSAJE_DE_OPERACION);]]>
</Text>
</Rung>
<Rung Number="37" Type="N">
<Comment>
<![CDATA[######################################################################################################################################################################################
PONE EL ROBOT YAMAHA EN MODO MANUAL 
######################################################################################################################################################################################]]>
</Comment>
<Text>
<![CDATA[XIC(MODO_AUTO_OFF)XIC(ENTRADA_L5_I_26)XIO(MAQ_EN_SECC_ON_AUTO)XIO(Modo_Auto)[OTE(DRIVER_OFF_INTR_ROBOT) ,OTE(DRIV_ACT_MAN_ROB_YAM) ];]]>
</Text>
</Rung>
<Rung Number="38" Type="N">
<Text>
<![CDATA[XIC(MODO_AUTO_OFF)XIO(ENTRADA_L5_I_26)OTE(RST_ROBOT_YAMAHA);]]>
</Text>
</Rung>
<Rung Number="39" Type="N">
<Comment>
<![CDATA[#####################################################################################################################################################################################
CUANDO HAYA UN PARO DE EMERGENCIA PONES LA MAQUINA EN MODO MANUAL Y HAY QUE ENVIAR A ORIGEN TODO
#####################################################################################################################################################################################]]>
</Comment>
<Text>
<![CDATA[XIO(ENTRADA_L3_I_00)[OTU(SECC_ORIGEN_ECHA) ,OTU(SEC_DESCARGA_PALLET_ECHA) ,MOVE(0,SEC_HORNO_AUTO) ,OTU(DRIVER_ACT_FRENO_H) ,OTU(DRIVER_ACT_MOTOR) ,MOVE(0,SEC_DISPENSADO) ,MOVE(0,SEC_PALL_ENTRADA) ,MOVE(0,SEC_PALL_PRECC) ,MOVE(0,SEC_ELEV_IN) ,OTU(PALLET_EN_ELEVADOR) ];]]>
</Text>
</Rung>
<Rung Number="40" Type="N">
<Comment>
<![CDATA[################################################################################################################################################################################
EN MODO MANUAL PONE TODAS LAS SECCUENCIAS DE AUTOMATICO ASI COMO LOS DRIVERS EN 0
###############################################################################################################################################################################]]>
</Comment>
<Text>
<![CDATA[[XIO(Modo_Auto) ,EQ(Sec_Inicial,20) ][OTU(DRIVER_ACT_FRENO_H) ,OTU(DRIVER_ACT_MOTOR) ,MOVE(0,SEC_DISPENSADO) ,MOVE(0,SEC_PALL_ENTRADA) ,MOVE(0,SEC_PALL_PRECC) ,MOVE(0,SEC_ELEV_OUT) ,MOVE(0,SEC_ELEVADOR_SALIDA) ,MOVE(0,SEC_PURGADO) ,MOVE(0,SEC_MEZCLADO) ,OTU(SEC_DESCARGA_PALLET_ECHA) ,MOVE(0,SEC_HORNO_AUTO) ,MOVE(0,SEC_ELEV_IN) ,MOVE(0,SEC_ELEVADOR_SALIDA) ,MOVE(0,Sec_By_Pass_Disp) ,MOVE(0,Sec_By_Pass_Disp_Driv) ];]]>
</Text>
</Rung>
<Rung Number="41" Type="N">
<Text>
<![CDATA[[XIO(Modo_Auto) ,EQ(Sec_Inicial,20) ][MOVE(0,DRIVERS_ACT_AUTO_L7) ,MOVE(0,DRIVERS_ACT_AUTO_L8) ,MOVE(0,DRIVERS_ACT_AUTO_L9) ,MOVE(0,DRIVERS_ACT_AUTO_L10) ,MOVE(0,DRIVERS_DES_AUTO_L7) ,MOVE(0,DRIVERS_DES_AUTO_L8) ,MOVE(0,DRIVERS_DES_AUTO_L9) ,MOVE(0,DRIVERS_DES_AUTO_L10) ,[XIC(ENTRADA_L4_I_15) ,XIC(ENTRADA_L6_I_11) ] OTL(HORNO_LISTO_ENVIAR) ,OTU(PALLET_EN_ELEVADOR) ];]]>
</Text>
</Rung>
